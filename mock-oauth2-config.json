{
  "interactiveLogin": false,
  "tokenCallbacks": [
    {
      "issuerId": "default",
      "tokenExpiry": 3600,
      "requestMappings": [
        {
          "requestParam": "grant_type",
          "match": "client_credentials",
          "claims": {
            "aud": "default",
            "roles": ["Applications.Read"]
          }
        }
      ]
    }
  ]
}
